{
  "name": "@browser-replay/snapshot",
  "version": "0.0.1",
  "description": "browser-replay's component to take a snapshot of DOM, aka DOM serializer",
  "scripts": {
    "retest": "vitest run",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "retest:update": "vitest run --update",
    "test:update": "pnpm build && vitest run --update",
    "bench": "vite build && vitest bench",
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc --noEmit --pretty",
    "prepublish": "pnpm check-types && vite build",
    "lint": "pnpm eslint src"
  },
  "type": "module",
  "keywords": [
    "browser-replay",
    "snapshot",
    "DOM"
  ],
  "main": "./dist/snapshot.umd.cjs",
  "module": "./dist/snapshot.js",
  "unpkg": "./dist/snapshot.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/snapshot.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/snapshot.cjs"
      }
    },
    "./snapshot-utils": {
      "types": "./dist/snapshot-utils.d.ts",
      "import": "./dist/snapshot-utils.js"
    },
    "./rebuild-utils": {
      "types": "./dist/rebuild-utils.d.ts",
      "import": "./dist/rebuild-utils.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/types": "workspace:*",
    "@browser-replay/utils": "workspace:*",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "postcss": "^8.5.15"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/snapshot"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/snapshot#readme"
}
