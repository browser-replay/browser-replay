{
  "name": "@dom-replay/snapshot",
  "version": "0.0.1",
  "description": "dom-replay's component to take a snapshot of DOM, aka DOM serializer",
  "scripts": {
    "retest": "vitest run",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest watch",
    "retest:update": "vitest run --update",
    "test:update": "pnpm build && vitest run --update",
    "bench": "vite build && vitest bench",
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc --noEmit",
    "prepublish": "pnpm check-types && vite build",
    "lint": "pnpm eslint src"
  },
  "type": "module",
  "keywords": [
    "dom-replay",
    "snapshot",
    "DOM"
  ],
  "main": "./dist/snapshot.umd.cjs",
  "module": "./dist/snapshot.js",
  "unpkg": "./dist/snapshot.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/snapshot.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/snapshot.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "license": "MIT",
  "devDependencies": {
    "@dom-replay/types": "workspace:*",
    "@dom-replay/utils": "workspace:*",
    "@types/jsdom": "^20.0.0",
    "@types/node": "^18.15.11",
    "jsdom": "^28.0.0",
    "puppeteer": "^24.36.1",
    "ts-node": "^7.0.1",
    "tslib": "^1.9.3",
    "typescript": "5.8.2",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "postcss": "^8.5.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}