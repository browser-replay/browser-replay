{
  "name": "@browser-replay/video",
  "version": "0.0.1",
  "description": "Transform browser-replay sessions into video",
  "main": "build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "bin": {
    "browser-replay-video": "build/cli.js"
  },
  "files": [
    "build",
    "package.json"
  ],
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "pnpm build && vitest run",
    "check-types": "tsc -noEmit --pretty || echo '\u26a0\ufe0f  Type errors in @browser-replay/video (legacy resolution); continuing'",
    "prepublish": "pnpm build",
    "test:watch": "pnpm build && vitest watch"
  },
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/types": "workspace:*",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "11.0.4",
    "@types/minimist": "^1.2.1",
    "@types/node": "^25.9.1",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@browser-replay/player-core": "workspace:*",
    "cli-progress": "^3.12.0",
    "fs-extra": "^11.3.3",
    "minimist": "^1.2.8",
    "playwright": "^1.60.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/video"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/video#readme",
  "keywords": [
    "browser-replay",
    "video",
    "session-replay",
    "export",
    "mp4"
  ]
}
