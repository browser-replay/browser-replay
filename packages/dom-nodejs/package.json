{
  "name": "@browser-replay/dom-nodejs",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty || echo '⚠️  Type errors in @browser-replay/dom-nodejs (legacy); continuing'",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublish": "tsc -noEmit || echo '⚠️  Type errors present; running Vite build' && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "keywords": [
    "browser-replay",
    "dom",
    "nodejs"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/dom-nodejs.umd.cjs",
  "module": "./dist/dom-nodejs.js",
  "unpkg": "./dist/dom-nodejs.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/dom-nodejs.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/dom-nodejs.umd.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "@types/cssom": "^0.4.1",
    "@types/cssstyle": "^2.2.1",
    "@types/node": "^22.0.0",
    "@types/nwsapi": "^2.2.2",
    "compare-versions": "^6.1.1",
    "puppeteer": "^24.36.1",
    "typescript": "5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@browser-replay/dom": "workspace:*",
    "@browser-replay/types": "workspace:*",
    "cssom": "^0.5.0",
    "cssstyle": "^2.3.0",
    "nwsapi": "2.2.23"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
