{
  "name": "@dom-replay/dom-nodejs",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "keywords": ["dom-replay", "dom", "nodejs"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/dom-nodejs.umd.cjs",
  "module": "./dist/dom-nodejs.js",
  "unpkg": "./dist/dom-nodejs.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/dom-nodejs.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/dom-nodejs.umd.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "@types/cssom": "^0.4.1",
    "@types/cssstyle": "^2.2.1",
    "@types/nwsapi": "^2.2.2",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "compare-versions": "^6.1.1",
    "eslint": "^9.39.2",
    "puppeteer": "^24.36.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "cssom": "^0.5.0",
    "cssstyle": "^2.3.0",
    "nwsapi": "2.2.0",
    "@dom-replay/dom": "workspace:*",
    "@dom-replay/types": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
