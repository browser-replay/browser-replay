{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src",
    "vite-env.d.ts"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    // Don't remove baseUrl — paths→source resolution needs it (else TS6305).
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@browser-replay/player-core": [
        "../player-core/src/index.ts"
      ]
    },
    // Legacy package after strict TS modernization
    "strict": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },
  "references": [
    {
      "path": "../player-core"
    }
  ]
}