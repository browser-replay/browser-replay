{
  "name": "@browser-replay/player",
  "version": "0.0.1",
  "description": "React wrapper around @browser-replay/player-core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./headless": {
      "import": {
        "types": "./dist/headless.d.mts",
        "default": "./dist/headless.mjs"
      },
      "require": {
        "types": "./dist/headless.d.cts",
        "default": "./dist/headless.cjs"
      }
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm run prepublish",
    "start": "vite --config demo/vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "check-types": "tsc -p tsconfig.build.json --noEmit --pretty",
    "prepublish": "tsc -p tsconfig.build.json --noEmit --pretty && tsdown",
    "lint": "pnpm eslint 'src/**/*.{ts,tsx}'"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@browser-replay/player-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/player"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/player#readme",
  "keywords": [
    "browser-replay",
    "player",
    "react",
    "session-replay",
    "replay"
  ]
}
