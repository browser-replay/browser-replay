{
  "name": "@dom-replay/player",
  "version": "0.0.1",
  "devDependencies": {
    "@dom-replay/types": "workspace:*",
    "@dom-replay/snapshot": "workspace:*",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint-plugin-svelte": "^3.14.0",
    "fast-glob": "^3.3.3",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte-preprocess": "^6.0.3",
    "svelte2tsx": "^0.7.30",
    "tslib": "^2.8.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "4.5.4"
  },
  "dependencies": {
    "@dom-replay/packer": "workspace:*",
    "@dom-replay/replay": "workspace:*",
    "@tsconfig/svelte": "^1.0.0"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "prepublishOnly": "pnpm build",
    "start": "vite",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "prepublish": "pnpm build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "description": "rrweb's replayer UI",
  "main": "./dist/player.umd.cjs",
  "module": "./dist/player.js",
  "unpkg": "./dist/player.umd.cjs",
  "typings": "dist/player.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/player.d.ts",
        "default": "./dist/player.js"
      },
      "require": {
        "types": "./dist/player.d.cts",
        "default": "./dist/player.cjs"
      }
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "keywords": [
    "rrweb"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
