{
  "name": "@browser-replay/player",
  "version": "0.0.1",
  "description": "React wrapper around @browser-replay/player-core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/player.cjs",
  "module": "./dist/player.js",
  "typings": "./dist/player.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/player.d.ts",
        "default": "./dist/player.js"
      },
      "require": {
        "types": "./dist/player.d.cts",
        "default": "./dist/player.cjs"
      }
    },
    "./headless": {
      "import": {
        "types": "./dist/headless.d.ts",
        "default": "./dist/headless.js"
      },
      "require": {
        "types": "./dist/headless.d.cts",
        "default": "./dist/headless.cjs"
      }
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "start": "vite --config demo/vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "check-types": "tsc -p tsconfig.build.json --noEmit --pretty || echo '⚠️  Type errors in @browser-replay/player (legacy); continuing'",
    "prepublish": "tsc -p tsconfig.build.json --noEmit --pretty || echo '⚠️  Type errors (see tsconfig); continuing with Vite build' && vite build",
    "lint": "pnpm eslint 'src/**/*.{ts,tsx}'"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@browser-replay/player-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
