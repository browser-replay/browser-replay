{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /**
     * `tsconfig.json` is auto-generated by `references:update` and is optimized
     * for editor/source navigation (it maps workspace deps to `src/`).
     *
     * For package builds we want to typecheck against the referenced packages'
     * built declarations instead, otherwise `tsc` can error with TS6305.
     */
    "paths": {},
    "disableSourceOfProjectReferenceRedirect": true
  }
}