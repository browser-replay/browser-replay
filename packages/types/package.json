{
  "name": "@dom-replay/types",
  "version": "0.0.3",
  "keywords": [
    "dom-replay",
    "@dom-replay/types"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/types.umd.cjs",
  "module": "./dist/types.js",
  "unpkg": "./dist/types.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/types.umd.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "@types/dom-mediacapture-transform": "0.1.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.15.11",
    "@types/offscreencanvas": "^2019.6.4",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
