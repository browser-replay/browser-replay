{
  "name": "@browser-replay/types",
  "version": "0.0.1",
  "keywords": [
    "browser-replay",
    "@browser-replay/types"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit",
    "prepublish": "tsdown",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "@types/dom-mediacapture-transform": "0.1.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/offscreencanvas": "^2019.6.4",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.0"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/types"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/types#readme",
  "description": "Shared TypeScript types for browser-replay"
}
