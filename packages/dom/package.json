{
  "name": "@browser-replay/dom",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/dom.cjs",
  "module": "./dist/dom.js",
  "unpkg": "./dist/dom.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/dom.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/dom.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty || echo '⚠️  Type errors in @browser-replay/dom (legacy code); continuing'",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublish": "tsc -noEmit || echo '⚠️  Type errors present (see tsconfig.json); running Vite build' && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "devDependencies": {
    "@browser-replay/types": "workspace:*",
    "jsdom": "^25.0.0",
    "puppeteer": "^24.36.1",
    "typescript": "5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@browser-replay/snapshot": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
