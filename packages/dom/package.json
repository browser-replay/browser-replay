{
  "name": "@browser-replay/dom",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/dom.cjs",
  "module": "./dist/dom.js",
  "unpkg": "./dist/dom.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/dom.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/dom.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty || echo '\u26a0\ufe0f  Type errors in @browser-replay/dom (legacy code); continuing'",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublish": "tsc -noEmit || echo '\u26a0\ufe0f  Type errors present (see tsconfig.json); running Vite build' && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "devDependencies": {
    "@browser-replay/types": "workspace:*",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@browser-replay/snapshot": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/dom"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/dom#readme",
  "description": "Virtual DOM implementation for browser-replay",
  "keywords": [
    "browser-replay",
    "dom",
    "virtual-dom",
    "session-replay"
  ]
}
