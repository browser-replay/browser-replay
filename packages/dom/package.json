{
  "name": "@browser-replay/dom",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublish": "tsc -noEmit && tsdown",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@browser-replay/snapshot": "workspace:*",
    "@browser-replay/types": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/dom"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/dom#readme",
  "description": "Virtual DOM implementation for browser-replay",
  "keywords": [
    "browser-replay",
    "dom",
    "virtual-dom",
    "session-replay"
  ]
}
