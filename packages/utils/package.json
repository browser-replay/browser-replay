{
  "name": "@browser-replay/utils",
  "version": "0.0.1",
  "keywords": [
    "browser-replay",
    "@browser-replay/utils"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit",
    "prepublish": "tsdown",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "tsdown": "^0.22.2",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/utils"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/utils#readme",
  "description": "Shared utilities for browser-replay"
}
