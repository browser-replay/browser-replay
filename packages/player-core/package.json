{
  "name": "@dom-replay/player-core",
  "version": "0.0.3",
  "description": "Framework-agnostic headless player built on @dom-replay/replay.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/player-core.cjs",
  "module": "./dist/player-core.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/player-core.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/player-core.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check-types": "tsc -noEmit",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "pnpm eslint 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@dom-replay/packer": "workspace:*",
    "@dom-replay/replay": "workspace:*",
    "@dom-replay/snapshot": "workspace:*",
    "@dom-replay/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.8.2",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.4.0"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
