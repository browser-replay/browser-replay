{
  "name": "@browser-replay/player-core",
  "version": "0.0.1",
  "description": "Framework-agnostic headless player built on @browser-replay/replay.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm run prepublish",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "check-types": "tsc -noEmit --pretty",
    "prepublish": "tsc -noEmit --pretty && tsdown",
    "lint": "pnpm eslint 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@browser-replay/packer": "workspace:*",
    "@browser-replay/replay": "workspace:*",
    "@browser-replay/snapshot": "workspace:*",
    "@browser-replay/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/player-core"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/player-core#readme",
  "keywords": [
    "browser-replay",
    "player",
    "session-replay",
    "replay"
  ]
}
