{
  "extends": "../../../tsconfig.base.json",
  "include": [
    "src"
  ],
  "exclude": [
    "vite.config.ts",
    "dist",
    "tsconfig.json"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    // Legacy — disable strict flags from base.
    "strict": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },
  "references": [
    {
      "path": "../../core"
    },
    {
      "path": "../plugin-sequential-id-record"
    },
    {
      "path": "../../types"
    }
  ]
}
