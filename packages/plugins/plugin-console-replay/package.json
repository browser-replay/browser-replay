{
  "name": "@browser-replay/plugin-console-replay",
  "version": "0.0.1",
  "description": "browser-replay plugin to replay console output",
  "type": "module",
  "main": "./dist/plugin-console-replay.umd.cjs",
  "module": "./dist/plugin-console-replay.js",
  "unpkg": "./dist/plugin-console-replay.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/plugin-console-replay.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/plugin-console-replay.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty",
    "prepublish": "tsc -noEmit --pretty && vite build"
  },
  "keywords": [
    "browser-replay"
  ],
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/plugin-console-record": "workspace:*",
    "@browser-replay/types": "workspace:*",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.0"
  },
  "peerDependencies": {
    "@browser-replay/core": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/plugins/plugin-console-replay"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/plugins/plugin-console-replay#readme"
}
