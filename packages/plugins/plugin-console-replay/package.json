{
  "name": "@browser-replay/plugin-console-replay",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/plugin-console-replay.umd.cjs",
  "module": "./dist/plugin-console-replay.js",
  "unpkg": "./dist/plugin-console-replay.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/plugin-console-replay.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/plugin-console-replay.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty || echo '⚠️  Type errors (legacy plugin); continuing'",
    "prepublish": "tsc -noEmit --pretty || echo '⚠️  Type errors; continuing with Vite build' && vite build"
  },
  "keywords": [
    "browser-replay"
  ],
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/plugin-console-record": "workspace:*",
    "@browser-replay/types": "workspace:*",
    "typescript": "5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^5.0.0"
  },
  "peerDependencies": {
    "@browser-replay/core": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
