{
  "name": "@browser-replay/plugin-console-record",
  "version": "0.0.1",
  "description": "browser-replay plugin to record console output",
  "type": "module",
  "main": "./dist/plugin-console-record.umd.cjs",
  "module": "./dist/plugin-console-record.js",
  "unpkg": "./dist/plugin-console-record.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/plugin-console-record.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/plugin-console-record.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit",
    "prepublish": "tsc -noEmit && vite build"
  },
  "keywords": [
    "browser-replay"
  ],
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/types": "workspace:*",
    "@browser-replay/utils": "workspace:*",
    "puppeteer": "^25.1.0",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/utils": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/plugins/plugin-console-record"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/plugins/plugin-console-record#readme"
}
