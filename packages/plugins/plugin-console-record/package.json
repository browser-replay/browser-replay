{
  "name": "@browser-replay/plugin-console-record",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/plugin-console-record.umd.cjs",
  "module": "./dist/plugin-console-record.js",
  "unpkg": "./dist/plugin-console-record.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/plugin-console-record.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/plugin-console-record.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "build": "pnpm run prepublish",
