    "@browser-replay/utils": "workspace:*",
    "puppeteer": "^25.1.0",
    "typescript": "5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/utils": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
