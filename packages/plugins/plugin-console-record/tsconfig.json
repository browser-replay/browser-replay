{
  "extends": "../../../tsconfig.base.json",
  "include": [
    "src"
  ],
  "exclude": [
    "vite.config.ts",
    "vitest.config.ts",
    "test"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    // TODO: enable me in the future
    // at time of writing (April 2024) there are 6 errors in this package
    "strict": false,
    // These two require strictNullChecks (enabled by strict:true in base).
    // This plugin deliberately runs with reduced strictness; disable the advanced flags
    // so tsc doesn't error with TS5052 during build/check.
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    // Additional base strict-derived flags that must be explicitly disabled here
    // so tsc checks continue to succeed for this package (per its TODO).
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },
  "references": [
    {
      "path": "../../core"
    },
    {
      "path": "../../types"
    },
    {
      "path": "../../utils"
    }
  ]
}
