{
  "name": "@browser-replay/plugin-canvas-webrtc-replay",
  "version": "0.0.1",
  "description": "browser-replay plugin to replay canvas via WebRTC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty",
    "prepublish": "tsc -noEmit && tsdown"
  },
  "keywords": [
    "browser-replay"
  ],
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/dom": "workspace:*",
    "@browser-replay/snapshot": "workspace:*",
    "@types/dom-mediacapture-transform": "0.1.11",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "peerDependencies": {
    "@browser-replay/core": "workspace:^",
    "@browser-replay/dom": "workspace:^",
    "@browser-replay/snapshot": "workspace:^"
  },
  "dependencies": {
    "simple-peer-light": "^9.10.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/plugins/plugin-canvas-webrtc-replay"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/plugins/plugin-canvas-webrtc-replay#readme"
}
