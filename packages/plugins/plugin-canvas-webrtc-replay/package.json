{
  "name": "@browser-replay/plugin-canvas-webrtc-replay",
  "version": "0.0.1",
  "description": "browser-replay plugin to replay canvas via WebRTC",
  "type": "module",
  "main": "./dist/plugin-canvas-webrtc-replay.umd.cjs",
  "module": "./dist/plugin-canvas-webrtc-replay.js",
  "unpkg": "./dist/plugin-canvas-webrtc-replay.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/plugin-canvas-webrtc-replay.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/plugin-canvas-webrtc-replay.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "check-types": "tsc -noEmit --pretty || echo '\u26a0\ufe0f  Type errors (legacy plugin); continuing'",
    "prepublish": "tsc -noEmit || echo '\u26a0\ufe0f  Type errors present; running Vite build' && vite build"
  },
  "keywords": [
    "browser-replay"
  ],
  "license": "MIT",
  "devDependencies": {
    "@browser-replay/core": "workspace:*",
    "@browser-replay/dom": "workspace:*",
    "@browser-replay/snapshot": "workspace:*",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "peerDependencies": {
    "@browser-replay/core": "workspace:*"
  },
  "dependencies": {
    "simple-peer-light": "^9.10.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/plugins/plugin-canvas-webrtc-replay"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/plugins/plugin-canvas-webrtc-replay#readme"
}
