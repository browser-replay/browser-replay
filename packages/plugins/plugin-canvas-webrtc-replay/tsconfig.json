{
  "extends": "../../../tsconfig.base.json",
  "include": [
    "src"
  ],
  "exclude": [
    "vite.config.ts"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    // For the experimental MediaStreamTrackProcessor global; not auto-included.
    "types": ["dom-mediacapture-transform"],
    // Legacy — disable strict flags from base.
    "strict": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },
  "references": [
    {
      "path": "../../core"
    },
    {
      "path": "../../dom"
    },
    {
      "path": "../../snapshot"
    }
  ]
}
