{
  "name": "@browser-replay/packer",
  "version": "0.0.1",
  "keywords": [
    "browser-replay",
    "@browser-replay/packer"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run prepublish",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check-types": "tsc -noEmit",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/packer.cjs",
  "module": "./dist/packer.js",
  "unpkg": "./dist/packer.js",
  "typings": "dist/packer.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/packer.d.ts",
        "default": "./dist/packer.js"
      },
      "require": {
        "types": "./dist/packer.d.cts",
        "default": "./dist/packer.cjs"
      }
    },
    "./pack": {
      "import": {
        "types": "./dist/pack.d.ts",
        "default": "./dist/pack.js"
      },
      "require": {
        "types": "./dist/pack.d.cts",
        "default": "./dist/pack.cjs"
      }
    },
    "./unpack": {
      "import": {
        "types": "./dist/unpack.d.ts",
        "default": "./dist/unpack.js"
      },
      "require": {
        "types": "./dist/unpack.d.cts",
        "default": "./dist/unpack.cjs"
      }
    }
  },
  "files": [
    "pack",
    "unpack",
    "build",
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@browser-replay/types": "workspace:*",
    "fflate": "^0.8.3"
  },
  "browserslist": [
    "supports es6-class"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "author": "browser-replay maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/browser-replay/browser-replay.git",
    "directory": "packages/packer"
  },
  "bugs": "https://github.com/browser-replay/browser-replay/issues",
  "homepage": "https://github.com/browser-replay/browser-replay/tree/master/packages/packer#readme",
  "description": "Event compression and packing for browser-replay"
}
