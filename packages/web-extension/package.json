{
  "name": "@browser-replay/web-extension",
  "private": true,
  "version": "0.0.1",
  "description": "The web extension for browser-replay.",
  "author": "browser-replay maintainers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:chrome": "cross-env TARGET_BROWSER=chrome vite dev",
    "dev:firefox": "cross-env TARGET_BROWSER=firefox vite dev",
    "build:chrome": "cross-env TARGET_BROWSER=chrome vite build",
    "build:firefox": "cross-env TARGET_BROWSER=firefox vite build",
    "pack:chrome": "cross-env TARGET_BROWSER=chrome ZIP=true vite build",
    "pack:firefox": "cross-env TARGET_BROWSER=firefox ZIP=true vite build",
    "check-types": "tsc -noEmit --pretty || echo '⚠️  Type errors in web-extension (legacy); continuing'",
    "build": "npm run pack:chrome && npm run pack:firefox",
    "prepublish": "pnpm build"
  },
  "devDependencies": {
    "@browser-replay/types": "workspace:*",
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.5.8",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.2",
    "semver": "^7.8.1",
    "type-fest": "^5.7.0",
    "vite": "^8.0.16",
    "vite-plugin-web-extension": "^4.5.1",
    "vite-plugin-zip-pack": "^1.2.2",
    "webextension-polyfill": "^0.12.0"
  },
  "//": "NOTE: This package is PRIVATE (not published). Several of its devDependencies (vite-plugin-web-extension and transitive web-ext-run / adbkit) pull in older node-forge and tmp with known high-severity CVEs. These are only used for local extension development/build. The root pnpm.overrides pins the worst offenders globally. If you need to run extension dev tooling, accept the risk or isolate this package further.",
  "dependencies": {
    "@chakra-ui/react": "^2.10.9",
    "@browser-replay/core": "workspace:*",
    "@browser-replay/player": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@tanstack/react-table": "^8.21.3",
    "framer-motion": "^12.40.0",
    "idb": "^8.0.3",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.16.0"
  }
}
