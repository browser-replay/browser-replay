{
  "name": "dom-replay",
  "description": "Record and replay DOM interactions.",
  "keywords": [
    "dom-replay",
    "session-replay",
    "replay",
    "record",
    "dom"
  ],
  "author": "dom-replay maintainers",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "devDependencies": {
    "@monorepo-utils/workspaces-to-typescript-project-references": "^2.8.2",
    "@types/dom-mediacapture-transform": "0.1.11",
    "@types/offscreencanvas": "^2019.6.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "browserslist": "^4.22.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.2",
    "esbuild-plugin-umd-wrapper": "^3.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-compat": "^6.1.0",
    "eslint-plugin-jest": "^29.12.2",
    "eslint-plugin-tsdoc": "^0.5.0",
    "happy-dom": "^20.5.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.47.0",
    "prettier": "3.8.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "turbo": "^2.8.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build:all": "NODE_OPTIONS='--max-old-space-size=4096' pnpm turbo run prepublish",
    "references:update": "pnpm workspaces-to-typescript-project-references",
    "test": "pnpm turbo run test --concurrency=1 --continue",
    "test:watch": "pnpm turbo run test:watch",
    "test:update": "pnpm turbo run test:update",
    "check-types": "pnpm turbo run check-types --continue",
    "format": "pnpm prettier --write '**/*.{ts,md}'",
    "format:head": "git diff --name-only HEAD^ |grep '\\.ts$\\|\\.md$' |xargs pnpm prettier --write",
    "dev": "pnpm turbo run dev --concurrency=18",
    "repl": "cd packages/core && npm run repl",
    "live-stream": "cd packages/core && pnpm live-stream",
    "lint": "pnpm concurrently --success=all -r -m=1 'pnpm markdownlint docs' 'ESLINT_USE_FLAT_CONFIG=false pnpm eslint packages/*/src --ext .ts,.tsx,.js,.jsx,.svelte'",
    "lint:report": "ESLINT_USE_FLAT_CONFIG=false pnpm eslint --output-file eslint_report.json --format json packages/*/src --ext .ts,.tsx,.js,.jsx"
  },
  "pnpm": {
    "overrides": {
      "cssom": "https://registry.npmjs.org/rrweb-cssom/-/rrweb-cssom-0.6.0.tgz",
      "@types/dom-webcodecs": "0.1.5"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "browserslist": [
    "defaults",
    "not op_mini all"
  ],
  "version": "0.0.1"
}
